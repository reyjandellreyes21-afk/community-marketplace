PORT=4000
# Atlas: use "Connect" → "Drivers" and copy the mongodb+srv://... string (URL-encode special chars in password).
MONGO_URI=mongodb://127.0.0.1:27017/quiz_app
# Set to true only for local UI testing when Atlas IP is blocked (quiz/auth need a real DB).
# If you still see DATABASE_DISABLED after setting false, clear SKIP_DATABASE from Windows User env or an old shell session — server loads .env with override.
SKIP_DATABASE=false
JWT_SECRET=replace_with_secure_secret
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
