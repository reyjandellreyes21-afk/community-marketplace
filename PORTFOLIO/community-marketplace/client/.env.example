# Defaults to same-origin /api/v1 (dev: Vite proxy to server; prod: configure your host).
# Set this when the API is on another origin (e.g. https://api.example.com/api/v1).
# VITE_API_URL=http://localhost:4000/api/v1

# Capacitor / native shell: build with relative asset paths (base ./).
# Prefer: npm run build:capacitor (uses .env.capacitor with VITE_CAPACITOR=true).
# VITE_CAPACITOR=true

# Optional: override Vite base URL (default production /linkmart/, dev /).
# VITE_APP_BASE=/linkmart/

VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
# Publishable key is safe to ship in the browser; authorization is enforced by Supabase Row Level Security (RLS).
# Never put the service role secret in any VITE_* variable or frontend code.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me

# Phone SMS verification (profile). Omit or leave false until Twilio is configured on the API.
# VITE_ENABLE_PHONE_VERIFICATION=true
