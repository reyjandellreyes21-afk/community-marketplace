# Never commit real keys (.env is gitignored). If keys leak, rotate them in Supabase Dashboard.
# Client builds must use only the publishable (anon) key — never the service role key.
PORT=4000
# Optional production: restrict browser origins that may call this API (comma-separated).
# Example: CORS_ORIGIN=https://your-app.pages.dev,https://your-app.vercel.app
# CORS_ORIGIN=
# Optional: default is community-images (created automatically on first upload when possible)
# COMMUNITY_IMAGES_BUCKET=my-existing-public-bucket
# No trailing slash — a trailing / breaks Storage API paths ("requested path is invalid").
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_replace_me
# Optional: Postgres URI from Supabase Dashboard → Project Settings → Database (for npm run db:apply-cart-fulfillment).
# DATABASE_URL=postgresql://postgres.[project-ref]:YOUR_DB_PASSWORD@aws-0-....pooler.supabase.com:6543/postgres
# Marketplace: after keys work, run ../supabase/sql_editor_all_in_one.sql in Supabase SQL Editor so public.listings (products) exists.
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Phone verification SMS (Twilio). Required for POST /auth/phone/send-code in production.
# Twilio Console → Account Info: Account SID + Auth Token.
# Option A — Messaging Service (recommended): Messaging → Services → create/copy SID starting with MG...
# Option B — single sender: Messaging → Senders / Phone Numbers → E.164 e.g. +15551234567
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Use ONE of the following (Messaging Service OR From number):
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+15551234567
